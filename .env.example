# Reference only. Supply these values through your shell, IDE, or deployment environment.
DB_URL=jdbc:postgresql://localhost:5432/team_access_hub
DB_USERNAME=<database-username>
DB_PASSWORD=<database-password>
JWT_SECRET=<base64-encoded-256-bit-key>
JWT_EXPIRATION_MS=86400000

# Required only when SPRING_PROFILES_ACTIVE includes dev.
DEMO_ADMIN_USERNAME=<development-admin-username>
DEMO_ADMIN_PASSWORD=<development-admin-password>
DEMO_ADMIN_EMAIL=<development-admin-email>
